@model AdminUserEditViewModel
@{
    ViewData["Title"] = "Редактирование пользователя";
}

<section class="section-shell">
    <div class="section-header">
        <div>
            <span class="section-kicker">Администрирование</span>
            <h1>Редактирование пользователя</h1>
        </div>

        <a class="btn btn-outline-secondary" asp-action="Index">Назад к списку</a>
    </div>

    <div class="content-card">
        <div class="preview-pane mb-4">
            <img src="@MediaCatalog.UserPhotoOrDefault(Model.PhotoUrl)" alt="Текущее фото пользователя" class="avatar-media avatar-media-xl" />
            <div>
                <span class="section-kicker">Превью</span>
                <h2>Фото пользователя</h2>
                <p class="mb-0 text-muted">Можно использовать локальный путь внутри приложения или внешнюю ссылку.</p>
            </div>
        </div>

        <form asp-action="EditUser" method="post" class="stack-list">
            @Html.AntiForgeryToken()
            <input asp-for="UserId" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="MiddleName" class="form-label"></label>
                    <input asp-for="MiddleName" class="form-control" />
                    <span asp-validation-for="MiddleName" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="BirthDate" class="form-label"></label>
                    <input asp-for="BirthDate" type="date" class="form-control" />
                    <span asp-validation-for="BirthDate" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Sex" class="form-label"></label>
                    <select asp-for="Sex" class="form-select">
                        <option value="true">Мужской</option>
                        <option value="false">Женский</option>
                    </select>
                    <span asp-validation-for="Sex" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="RoleId" class="form-label"></label>
                    <select asp-for="RoleId" asp-items="Model.AvailableRoles" class="form-select"></select>
                    <span asp-validation-for="RoleId" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" autocomplete="tel" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" autocomplete="username" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label asp-for="PhotoUrl" class="form-label"></label>
                    <input asp-for="PhotoUrl" class="form-control" placeholder="/images/demo/users/participant.svg или https://..." />
                    <span asp-validation-for="PhotoUrl" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>

            <p class="mb-0 text-muted">
                Поля пароля можно оставить пустыми, если пароль менять не нужно.
            </p>

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-accent">Сохранить изменения</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Отмена</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
