@model SportDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<section class="section-shell">
    <div class="content-card">
        <span class="section-kicker">Вид спорта</span>
        <h1>@Model.Title</h1>
        <div class="meta-row">
            <span>Типов: @Model.SportTypeCount</span>
            <span>Дисциплин: @Model.SportSubtypeCount</span>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-3">
            <a class="btn btn-outline-secondary" asp-action="Index">К списку видов спорта</a>
            @if (Model.CanManage)
            {
                <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Редактировать</a>
                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Удалить</a>
            }
        </div>
    </div>

    <div class="content-card">
        <div class="section-header">
            <div>
                <span class="section-kicker">Структура</span>
                <h2>Типы спорта и дисциплины</h2>
            </div>
        </div>
        @if (Model.SportTypes.Count == 0)
        {
            <div class="empty-state">Для этого вида спорта пока не добавлены типы.</div>
        }
        else
        {
            <div class="stack-list">
                @foreach (var sportType in Model.SportTypes)
                {
                    <article class="list-card compact-card">
                        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                            <div class="flex-grow-1">
                                <h3>@sportType.Title</h3>
                                <div class="badge-row mt-2">
                                    @foreach (var sportSubtypeTitle in sportType.SportSubtypeTitles)
                                    {
                                        <span class="badge text-bg-light">@sportSubtypeTitle</span>
                                    }
                                </div>
                            </div>
                            <div class="meta-block">
                                <span>Дисциплин: @sportType.SportSubtypeCount</span>
                            </div>
                        </div>
                        <div class="d-flex gap-2 mt-3">
                            <a class="btn btn-sm btn-outline-secondary" asp-controller="SportTypes" asp-action="Details" asp-route-id="@sportType.Id">Открыть тип</a>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>
