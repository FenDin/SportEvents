@model SportSubtypeDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<section class="section-shell">
    <div class="content-card">
        <span class="section-kicker">Дисциплина</span>
        <h1>@Model.Title</h1>
        <div class="meta-row">
            <span><a class="link-underline link-underline-opacity-0" asp-controller="Sports" asp-action="Details" asp-route-id="@Model.SportId">@Model.SportTitle</a> / <a class="link-underline link-underline-opacity-0" asp-controller="SportTypes" asp-action="Details" asp-route-id="@Model.SportTypeId">@Model.SportTypeTitle</a></span>
            <span>Соревнований: @Model.CompetitionCount</span>
            <span>Школ: @Model.SchoolCount</span>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-3">
            <a class="btn btn-outline-secondary" asp-action="Index">К списку дисциплин</a>
            @if (Model.CanManage)
            {
                <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Редактировать</a>
                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Удалить</a>
            }
        </div>
    </div>

    <div class="content-grid">
        <div class="content-card">
            <div class="section-header">
                <div>
                    <span class="section-kicker">Использование</span>
                    <h2>Соревнования</h2>
                </div>
            </div>
            @if (Model.CompetitionTitles.Count == 0)
            {
                <div class="empty-state">Эта дисциплина пока не используется в соревнованиях.</div>
            }
            else
            {
                <div class="badge-row">
                    @foreach (var competitionTitle in Model.CompetitionTitles)
                    {
                        <span class="badge text-bg-light">@competitionTitle</span>
                    }
                </div>
            }
        </div>

        <div class="content-card">
            <div class="section-header">
                <div>
                    <span class="section-kicker">Использование</span>
                    <h2>Школы</h2>
                </div>
            </div>
            @if (Model.SchoolTitles.Count == 0)
            {
                <div class="empty-state">Эта дисциплина пока не привязана к школам.</div>
            }
            else
            {
                <div class="badge-row">
                    @foreach (var schoolTitle in Model.SchoolTitles)
                    {
                        <span class="badge text-bg-light">@schoolTitle</span>
                    }
                </div>
            }
        </div>
    </div>
</section>
