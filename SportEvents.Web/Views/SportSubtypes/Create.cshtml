@model SportSubtypeEditViewModel
@{
    ViewData["Title"] = "Добавить дисциплину";
}

<section class="content-card form-card">
    <span class="section-kicker">Справочник спорта</span>
    <h1>Новая дисциплина</h1>
    <form asp-action="Create" method="post" class="stack-list mt-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div>
            <label asp-for="SportTypeId" class="form-label"></label>
            <select asp-for="SportTypeId" asp-items="Model.SportTypeOptions" class="form-select">
                <option value="">Выберите тип спорта</option>
            </select>
            <span asp-validation-for="SportTypeId" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-accent">Создать</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Отмена</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
