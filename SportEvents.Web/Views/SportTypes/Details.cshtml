@model SportTypeDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<section class="section-shell">
    <div class="content-card">
        <span class="section-kicker">Тип спорта</span>
        <h1>@Model.Title</h1>
        <div class="meta-row">
            <span>Вид спорта: <a class="link-underline link-underline-opacity-0" asp-controller="Sports" asp-action="Details" asp-route-id="@Model.SportId">@Model.SportTitle</a></span>
            <span>Дисциплин: @Model.SportSubtypeCount</span>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-3">
            <a class="btn btn-outline-secondary" asp-action="Index">К списку типов</a>
            @if (Model.CanManage)
            {
                <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Редактировать</a>
                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Удалить</a>
            }
        </div>
    </div>

    <div class="content-card">
        <div class="section-header">
            <div>
                <span class="section-kicker">Структура</span>
                <h2>Дисциплины внутри типа</h2>
            </div>
        </div>
        @if (Model.SportSubtypes.Count == 0)
        {
            <div class="empty-state">Для этого типа спорта пока не добавлены дисциплины.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Дисциплина</th>
                            <th>Соревнований</th>
                            <th>Школ</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sportSubtype in Model.SportSubtypes)
                        {
                            <tr>
                                <td class="fw-semibold">@sportSubtype.Title</td>
                                <td>@sportSubtype.CompetitionCount</td>
                                <td>@sportSubtype.SchoolCount</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-secondary" asp-controller="SportSubtypes" asp-action="Details" asp-route-id="@sportSubtype.Id">Открыть</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
