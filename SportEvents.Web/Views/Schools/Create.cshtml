@model SchoolEditViewModel
@{
    ViewData["Title"] = "Добавить школу";
}

<section class="content-card form-card">
    <span class="section-kicker">Каталог школ</span>
    <h1>Новая школа</h1>
    <form asp-action="Create" method="post" class="stack-list mt-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div>
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="SelectedSportSubtypeIds" class="form-label"></label>
            @if (Model.SportSubtypeOptions.Count == 0)
            {
                <div class="empty-state">Доступные дисциплины пока не найдены.</div>
            }
            else
            {
                <div class="selection-list">
                    @foreach (var option in Model.SportSubtypeOptions)
                    {
                        <label class="selection-item">
                            <input class="form-check-input mt-1" type="checkbox" name="SelectedSportSubtypeIds" value="@option.Id" @(option.IsSelected ? "checked=\"checked\"" : null) />
                            <span class="selection-copy">
                                <span class="fw-semibold d-block">@option.Label</span>
                            </span>
                        </label>
                    }
                </div>
            }
            <div class="form-text">Можно выбрать несколько дисциплин, которые доступны в школе.</div>
            <span asp-validation-for="SelectedSportSubtypeIds" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="SelectedParticipantIds" class="form-label"></label>
            @if (Model.ParticipantOptions.Count == 0)
            {
                <div class="empty-state">Свободные участники пока не найдены.</div>
            }
            else
            {
                <div class="selection-list">
                    @foreach (var option in Model.ParticipantOptions)
                    {
                        <label class="selection-item">
                            <input class="form-check-input mt-1" type="checkbox" name="SelectedParticipantIds" value="@option.Id" @(option.IsSelected ? "checked=\"checked\"" : null) />
                            <span class="selection-copy">
                                <span class="fw-semibold d-block">@option.Label</span>
                                @if (!string.IsNullOrWhiteSpace(option.Description))
                                {
                                    <span class="text-muted small">@option.Description</span>
                                }
                            </span>
                        </label>
                    }
                </div>
            }
            <div class="form-text">Выберите учащихся или выпускников, которых нужно закрепить за школой.</div>
            <span asp-validation-for="SelectedParticipantIds" class="text-danger"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-accent">Создать</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Отмена</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
