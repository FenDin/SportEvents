@model SchoolDetailsViewModel
@{
    ViewData["Title"] = "Удалить школу";
}

<section class="content-card narrow-card">
    <span class="section-kicker">Удаление</span>
    <h1>@Model.Title</h1>
    <p class="lead-text">Школа будет удалена, связанные дисциплины отвяжутся, а участники останутся в системе без закрепления за школой.</p>
    <div class="meta-row">
        <span>Участников: @Model.ParticipantCount</span>
        <span>Дисциплин: @Model.SportSubTypes.Count</span>
    </div>
    <form asp-action="Delete" method="post" class="d-flex gap-2 mt-4">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Удалить</button>
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Отмена</a>
    </form>
</section>
