@model EventCatalogViewModel
@{
    ViewData["Title"] = "События";
}

<section class="section-shell">
    <div class="section-header">
        <div>
            <span class="section-kicker">Каталог событий</span>
            <h1>Спортивные события</h1>
        </div>
        @if (Model.CanManage)
        {
            <a class="btn btn-accent" asp-action="Create">Создать событие</a>
        }
    </div>

    <form method="get" class="filter-panel">
        <input type="text" name="searchQuery" value="@Model.SearchQuery" class="form-control" placeholder="Поиск по названию или описанию" />
        <select name="status" class="form-select">
            <option value="all" selected="@(Model.Status == "all" ? "selected" : null)">Все</option>
            <option value="upcoming" selected="@(Model.Status == "upcoming" ? "selected" : null)">Актуальные</option>
            <option value="past" selected="@(Model.Status == "past" ? "selected" : null)">Прошедшие</option>
        </select>
        <button type="submit" class="btn btn-outline-secondary">Применить</button>
    </form>

    @if (Model.Items.Count == 0)
    {
        <div class="empty-state">По текущим фильтрам события не найдены.</div>
    }
    else
    {
        <div class="stack-list">
            @foreach (var item in Model.Items)
            {
                <article class="list-card">
                    <div class="d-flex justify-content-between gap-3 flex-wrap">
                        <div>
                            <h2>@item.Title</h2>
                            <p>@(string.IsNullOrWhiteSpace(item.Description) ? "Описание пока не заполнено." : item.Description)</p>
                            <div class="badge-row">
                                @foreach (var sport in item.Sports)
                                {
                                    <span class="badge text-bg-light">@sport</span>
                                }
                            </div>
                        </div>
                        <div class="meta-block">
                            <span>@item.DateStart?.ToString("dd.MM.yyyy HH:mm")</span>
                            <span>@item.DateEnd?.ToString("dd.MM.yyyy HH:mm")</span>
                            <span>@item.CompetitionCount соревнований</span>
                        </div>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Подробнее</a>
                        @if (Model.CanManage)
                        {
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Редактировать</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
                        }
                    </div>
                </article>
            }
        </div>
    }
</section>
