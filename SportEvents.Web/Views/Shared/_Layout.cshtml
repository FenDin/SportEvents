@using System.Security.Claims
@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var role = User.FindFirstValue(ClaimTypes.Role);
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var entityControllers = new[] { "Events", "Competitions", "Schools", "Sports", "SportTypes", "SportSubtypes" };
    var entitiesDropdownClass = entityControllers.Contains(currentController, StringComparer.OrdinalIgnoreCase)
        ? "nav-link dropdown-toggle active"
        : "nav-link dropdown-toggle";
    var displayName = string.Join(" ", new[]
    {
        User.FindFirstValue(ClaimTypes.GivenName),
        User.FindFirstValue(ClaimTypes.Surname)
    }.Where(item => !string.IsNullOrWhiteSpace(item)));

    if (string.IsNullOrWhiteSpace(displayName))
    {
        displayName = User.Identity?.Name ?? "Пользователь";
    }
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SportEvents</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SportEvents.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">SportEvents</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item dropdown">
                            <a class="@entitiesDropdownClass" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Сущности</a>
                            <ul class="dropdown-menu dropdown-menu-dark navbar-dropdown">
                                <li><a class="dropdown-item @(string.Equals(currentController, "Events", StringComparison.OrdinalIgnoreCase) ? "active" : null)" asp-controller="Events" asp-action="Index">События</a></li>
                                <li><a class="dropdown-item @(string.Equals(currentController, "Competitions", StringComparison.OrdinalIgnoreCase) ? "active" : null)" asp-controller="Competitions" asp-action="Index">Соревнования</a></li>
                                <li><a class="dropdown-item @(string.Equals(currentController, "Schools", StringComparison.OrdinalIgnoreCase) ? "active" : null)" asp-controller="Schools" asp-action="Index">Школы</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item @(string.Equals(currentController, "Sports", StringComparison.OrdinalIgnoreCase) ? "active" : null)" asp-controller="Sports" asp-action="Index">Виды спорта</a></li>
                                <li><a class="dropdown-item @(string.Equals(currentController, "SportTypes", StringComparison.OrdinalIgnoreCase) ? "active" : null)" asp-controller="SportTypes" asp-action="Index">Типы спорта</a></li>
                                <li><a class="dropdown-item @(string.Equals(currentController, "SportSubtypes", StringComparison.OrdinalIgnoreCase) ? "active" : null)" asp-controller="SportSubtypes" asp-action="Index">Дисциплины</a></li>
                            </ul>
                        </li>
                        @if (isAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase) ? "active" : null)" asp-controller="Home" asp-action="StartPage">Кабинет</a>
                            </li>
                        }
                        @if (User.IsInRole(AppRoles.Administrator))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(string.Equals(currentController, "Admin", StringComparison.OrdinalIgnoreCase) ? "active" : null)" asp-controller="Admin" asp-action="Index">Роли и пользователи</a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        @if (isAuthenticated)
                        {
                            <div class="user-pill">
                                <span class="fw-semibold">@displayName</span>
                                @if (!string.IsNullOrWhiteSpace(role))
                                {
                                    <span class="badge text-bg-light">@role</span>
                                }
                            </div>

                            <form asp-controller="User" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light">Выйти</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-outline-light" asp-controller="User" asp-action="Login">Вход</a>
                            <a class="btn btn-accent" asp-controller="User" asp-action="Register">Регистрация</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container page-shell">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
            <span>&copy; 2026 SportEvents</span>
            <span>Платформа для просмотра и управления спортивными событиями</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
