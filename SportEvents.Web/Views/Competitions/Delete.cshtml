@model CompetitionDetailsViewModel
@{
    ViewData["Title"] = "Удалить соревнование";
}

<section class="content-card narrow-card">
    <span class="section-kicker">Удаление</span>
    <h1>@Model.Title</h1>
    <p class="lead-text">Будут удалены привязки к событиям и записи участников на это соревнование.</p>
    <div class="badge-row">
        <span class="badge text-bg-light">@Model.SportTitle</span>
        <span class="badge text-bg-light">@Model.SportTypeTitle</span>
        <span class="badge text-bg-light">@Model.SportSubTypeTitle</span>
    </div>
    <div class="meta-row mt-3">
        <span>Начало: @Model.DateStart?.ToString("dd.MM.yyyy HH:mm")</span>
        <span>Окончание: @Model.DateEnd?.ToString("dd.MM.yyyy HH:mm")</span>
        <span>Участников: @Model.ParticipantCount</span>
    </div>
    <form asp-action="Delete" method="post" class="d-flex gap-2 mt-4">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Удалить</button>
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Отмена</a>
    </form>
</section>
