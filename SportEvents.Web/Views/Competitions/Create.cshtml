@model CompetitionEditViewModel
@{
    ViewData["Title"] = "Создать соревнование";
}

<section class="content-card form-card">
    <span class="section-kicker">Каталог соревнований</span>
    <h1>Новое соревнование</h1>
    <form asp-action="Create" method="post" class="stack-list mt-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div>
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="EventId" class="form-label"></label>
            <select asp-for="EventId" asp-items="Model.EventOptions" class="form-select">
                <option value="">Выберите событие</option>
            </select>
            <span asp-validation-for="EventId" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="SportSubTypeId" class="form-label"></label>
            <select asp-for="SportSubTypeId" asp-items="Model.SportSubtypeOptions" class="form-select">
                <option value="">Выберите дисциплину</option>
            </select>
            <span asp-validation-for="SportSubTypeId" class="text-danger"></span>
        </div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="DateStart" class="form-label"></label>
                <input asp-for="DateStart" class="form-control" />
                <span asp-validation-for="DateStart" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="DateEnd" class="form-label"></label>
                <input asp-for="DateEnd" class="form-control" />
                <span asp-validation-for="DateEnd" class="text-danger"></span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-accent">Создать</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Отмена</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
