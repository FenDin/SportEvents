@model CompetitionDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<section class="section-shell">
    <div class="content-card">
        <span class="section-kicker">Соревнование</span>
        <h1>@Model.Title</h1>
        <p class="lead-text">@(string.IsNullOrWhiteSpace(Model.Description) ? "Описание пока не заполнено." : Model.Description)</p>
        <div class="badge-row">
            <span class="badge text-bg-light">@Model.SportTitle</span>
            <span class="badge text-bg-light">@Model.SportTypeTitle</span>
            <span class="badge text-bg-light">@Model.SportSubTypeTitle</span>
        </div>
        <div class="meta-row mt-3">
            <span>Начало: @Model.DateStart?.ToString("dd.MM.yyyy HH:mm")</span>
            <span>Окончание: @Model.DateEnd?.ToString("dd.MM.yyyy HH:mm")</span>
            <span>Участников: @Model.ParticipantCount</span>
        </div>

        <div class="d-flex flex-wrap gap-2 mt-4">
            <a class="btn btn-outline-secondary" asp-action="Index">К списку соревнований</a>
            @if (Model.CanEnroll && !Model.IsUserEnrolled)
            {
                <form asp-action="Enroll" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-accent">Записаться</button>
                </form>
            }
            @if (Model.CanEnroll && Model.IsUserEnrolled)
            {
                <form asp-action="Leave" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-danger">Отменить участие</button>
                </form>
            }
            @if (Model.CanManage)
            {
                <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.Id">Редактировать</a>
                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Удалить</a>
            }
        </div>
    </div>

    <div class="content-grid">
        <div class="content-card">
            <div class="section-header">
                <div>
                    <span class="section-kicker">В рамках события</span>
                    <h2>Привязанные события</h2>
                </div>
            </div>
            <div class="stack-list">
                @foreach (var item in Model.Events)
                {
                    <article class="list-card compact-card">
                        <h3>@item.Title</h3>
                        <p class="mb-2">@item.DateStart?.ToString("dd.MM.yyyy HH:mm") - @item.DateEnd?.ToString("dd.MM.yyyy HH:mm")</p>
                        <a class="btn btn-sm btn-outline-secondary" asp-controller="Events" asp-action="Details" asp-route-id="@item.Id">Открыть событие</a>
                    </article>
                }
            </div>
        </div>

        <div class="content-card">
            <div class="section-header">
                <div>
                    <span class="section-kicker">Ролевая логика</span>
                    <h2>Что можно сделать</h2>
                </div>
            </div>
            <div class="stack-list">
                <article class="list-card compact-card">
                    <h3>Участник</h3>
                    <p>Может записаться или отменить участие, если соревнование ещё актуально.</p>
                </article>
                <article class="list-card compact-card">
                    <h3>Организатор</h3>
                    <p>Может редактировать параметры соревнования и его связь с событием.</p>
                </article>
                <article class="list-card compact-card">
                    <h3>Администратор</h3>
                    <p>Может удалять соревнования и назначать роли пользователям.</p>
                </article>
            </div>
        </div>
    </div>
</section>
